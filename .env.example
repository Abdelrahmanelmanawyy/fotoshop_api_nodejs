# Replicate API token (get from https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=r8_your_token_from_replicate_com

# GPT Image 2 on Replicate (openai/gpt-image-2)
# quality: low (~$0.012/img) | medium (~$0.047/img, default) | high (~$0.128) | auto (~$0.128)
# REPLICATE_GPT_IMAGE_QUALITY=medium
# aspect_ratio: 1:1 | 3:2 | 2:3
# REPLICATE_GPT_IMAGE_ASPECT_RATIO=1:1

# Direct OpenAI API for ChatGPT Image (gpt-image-1) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_IMAGE_SIZE=1024x1024

# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server port
PORT=3000

# PayTR payment credentials (from PayTR merchant panel)
PAYTR_MERCHANT_ID=your_store_number
PAYTR_MERCHANT_KEY=your_store_secret_key
PAYTR_MERCHANT_SALT=your_store_password
# Full URL PayTR will POST to after payment (must be HTTPS)
PAYTR_CALLBACK_URL=https://YOUR_NGROK_URL.ngrok-free.app/paytr/callback
# Set to 1 for test mode (use test card: 4355 0843 5508 4358)
PAYTR_TEST_MODE=1
# Print price in Turkish Lira (single session)
PRINT_PRICE_TRY=49.99

# PhotoXBox biometric processing (Laravel create-process → phont upload-image)
PHOTOXBOX_CREATE_PROCESS_URL=https://dashboard.photoxbox.com/api/create-process
PHONT_BASE_URL=https://phont.photoxbox.com
# Optional kiosk/cabin UUID for PhotoXBox
# PHOTOXBOX_CABIN_UUID=
PHONT_REQUEST_TIMEOUT_MS=120000
